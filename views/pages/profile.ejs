<%- include('../partials/header') %>

    <div style="padding: 80px 5%; max-width: 1200px; margin: 0 auto;">
        <!-- Profile Header -->
        <div style="text-align: center; margin-bottom: 80px;">
            <div
                style="width: 120px; height: 120px; border-radius: 50%; background: linear-gradient(135deg, var(--primary), var(--secondary)); display: flex; align-items: center; justify-content: center; font-size: 3rem; font-weight: 800; margin: 0 auto 24px; box-shadow: 0 20px 40px rgba(139, 92, 246, 0.3);">
                <%= user.name.charAt(0) %>
            </div>
            <h1 style="font-size: 2.5rem; font-weight: 800; margin-bottom: 12px;">
                <%= user.name %>
            </h1>
            <p style="color: var(--text-muted); font-size: 1.1rem;">
                <%= user.email %>
            </p>

            <div style="display: flex; justify-content: center; gap: 40px; margin-top: 40px;">
                <div style="text-align: center;">
                    <p style="font-size: 1.5rem; font-weight: 800;">
                        <%= posts.length %>
                    </p>
                    <p
                        style="color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase; font-weight: 700; letter-spacing: 1px;">
                        Stories Published</p>
                </div>
                <div style="text-align: center;">
                    <p style="font-size: 1.5rem; font-weight: 800;">1.2k</p>
                    <p
                        style="color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase; font-weight: 700; letter-spacing: 1px;">
                        Followers</p>
                </div>
            </div>
        </div>

        <!-- User Publications -->
        <div
            style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; border-bottom: 1px solid var(--border); padding-bottom: 20px;">
            <h3 style="font-size: 1.5rem; font-weight: 800;">Your Publications</h3>
            <a href="/create" class="btn" style="text-decoration: none; font-size: 0.9rem;">New Draft</a>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 30px;">
            <% if (posts && posts.length> 0) { %>
                <% posts.forEach(post=> { %>
                    <div class="profile-card"
                        style="background: var(--card-bg); border-radius: 24px; border: 1px solid var(--border); overflow: hidden; transition: 0.4s; position: relative;">
                        <img src="<%= post.imageUrl %>" style="width: 100%; height: 220px; object-fit: cover;">
                        <div style="padding: 24px;">
                            <span
                                style="color: var(--primary); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; display: block; margin-bottom: 8px;">Story</span>
                            <h4
                                style="font-size: 1.25rem; font-weight: 800; margin-bottom: 12px; line-height: 1.4; height: 3.5em; overflow: hidden;">
                                <%= post.title %>
                            </h4>
                            <div
                                style="display: flex; justify-content: space-between; align-items: center; margin-top: 24px;">
                                <span style="color: var(--text-muted); font-size: 0.85rem;">
                                    <%= post.createdAt.toDateString() %>
                                </span>
                                <div style="display: flex; gap: 15px;">
                                    <a href="/post/edit/<%= post.id %>"
                                        style="color: var(--text-muted); text-decoration: none; font-size: 1.1rem; transition: 0.3s;"><i
                                            class="fa-regular fa-pen-to-square"></i></a>
                                    <a href="/post/delete/<%= post.id %>" onclick="return confirm('Delete story?')"
                                        style="color: #ef4444; font-size: 1.1rem; transition: 0.3s;"><i
                                            class="fa-regular fa-trash-can"></i></a>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                        <% } else { %>
                            <div
                                style="grid-column: 1/-1; text-align: center; padding: 100px 0; background: var(--card-bg); border-radius: 32px; border: 1px dashed var(--border);">
                                <i class="fa-solid fa-feather-pointed"
                                    style="font-size: 3rem; color: var(--text-muted); margin-bottom: 20px;"></i>
                                <h3 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 10px;">You haven't
                                    written anything yet</h3>
                                <p style="color: var(--text-muted);">Your first story is waiting for you to tell it.</p>
                                <a href="/create" class="btn"
                                    style="margin-top: 30px; display: inline-block; text-decoration: none;">Start
                                    Writing</a>
                            </div>
                            <% } %>
        </div>
    </div>

    <style>
        .profile-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 30px 60px -15px rgba(0, 0, 0, 0.5);
            border-color: var(--primary);
        }

        .profile-card a:hover {
            color: var(--text) !important;
            transform: scale(1.1);
        }
    </style>

    <%- include('../partials/footer') %>