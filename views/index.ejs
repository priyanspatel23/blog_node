<%- include('partials/header') %>

    <!-- HERO SECTION -->
    <section class="hero"
        style="padding: 100px 5%; text-align: center; position: relative; overflow: hidden; background: radial-gradient(circle at top right, rgba(139, 92, 246, 0.15), transparent), radial-gradient(circle at bottom left, rgba(236, 72, 153, 0.1), transparent);">
        <div
            style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; opacity: 0.5;">
            <div
                style="position: absolute; top: 10%; left: 5%; width: 300px; height: 300px; background: var(--primary); filter: blur(150px); border-radius: 50%;">
            </div>
            <div
                style="position: absolute; bottom: 10%; right: 5%; width: 250px; height: 250px; background: var(--secondary); filter: blur(150px); border-radius: 50%;">
            </div>
        </div>

        <div style="position: relative; z-index: 1; max-width: 900px; margin: 0 auto;">
            <span
                style="background: rgba(139, 92, 246, 0.1); color: var(--primary); padding: 8px 16px; border-radius: 50px; font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 2px; border: 1px solid rgba(139, 92, 246, 0.2);">The
                Future of Blogging</span>
            <h1
                style="font-size: clamp(2.5rem, 8vw, 4.5rem); font-weight: 800; line-height: 1.1; margin: 24px 0; letter-spacing: -2px;">
                Explore stories that <span style="background: linear-gradient(135deg, var(--primary), var(--secondary));        background-clip: text;
        -webkit-background-clip: text;
 -webkit-text-fill-color: transparent;">inform
                    and inspire.</span></h1>
            <p
                style="font-size: 1.1rem; color: var(--text-muted); max-width: 600px; margin: 0 auto 40px; line-height: 1.7;">
                Join our community of elite writers and thinkers. Discover expert-led insights across technology,
                design, and culture.</p>
            <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
                <a href="/create" class="btn" style="text-decoration: none;">Start Writing</a>
                <a href="#blogs"
                    style="text-decoration: none; color: var(--text); padding: 0.7rem 1.8rem; border: 1px solid var(--border); border-radius: 50px; font-weight: 600; transition: 0.3s; background: rgba(255, 255, 255, 0.05);">Browse
                    Feed</a>
            </div>
        </div>
    </section>

    <!-- BLOG FEED -->
    <div id="blogs" style="padding: 80px 5%;">
        <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 50px;">
            <div>
                <h2 style="font-size: 2rem; font-weight: 700;">Latest Stories</h2>
                <div
                    style="width: 60px; height: 4px; background: linear-gradient(90deg, var(--primary), var(--secondary)); border-radius: 2px; margin-top: 10px;">
                </div>
            </div>
            <% if(user) { %>
                <a href="/create"
                    style="color: var(--primary); text-decoration: none; font-weight: 600; font-size: 0.9rem; display: flex; align-items: center; gap: 8px;">
                    <i class="fa-solid fa-plus"></i> NEW STORY
                </a>
                <% } %>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 30px;">
            <% if (posts && posts.length> 0) { %>
                <% posts.forEach(function(post) { %>
                    <article class="blog-card"
                        style="background: var(--card-bg); border-radius: 24px; border: 1px solid var(--border); overflow: hidden; transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); position: relative; height: 100%; display: flex; flex-direction: column;">
                        <a href="/post/<%= post.id %>"
                            style="display: block; position: relative; height: 240px; overflow: hidden;">
                            <img src="<%= post.imageUrl || 'https://images.unsplash.com/photo-1499750310107-5fef28a66643?q=80&w=1000' %>"
                                alt="<%= post.title %>"
                                style="width: 100%; height: 100%; object-fit: cover; transition: 0.5s;">
                            <div
                                style="position: absolute; top: 20px; right: 20px; background: rgba(0,0,0,0.5); backdrop-filter: blur(8px); padding: 5px 12px; border-radius: 8px; font-size: 0.75rem; font-weight: 600; color: #fff;">
                                <i class="fa-regular fa-clock" style="margin-right: 5px;"></i> 5 min read
                            </div>
                        </a>

                        <div style="padding: 30px; flex-grow: 1; display: flex; flex-direction: column;">
                            <div style="display: flex; gap: 10px; margin-bottom: 15px;">
                                <span
                                    style="font-size: 0.7rem; font-weight: 700; color: var(--primary); text-transform: uppercase; letter-spacing: 1px;">TECHNOLOGY</span>
                            </div>

                            <h3 style="font-size: 1.4rem; font-weight: 700; margin-bottom: 12px; line-height: 1.4;">
                                <a href="/post/<%= post.id %>"
                                    style="color: var(--text); text-decoration: none; transition: 0.3s;">
                                    <%= post.title %>
                                </a>
                            </h3>

                            <p
                                style="font-size: 0.95rem; color: var(--text-muted); line-height: 1.6; margin-bottom: 25px;">
                                <%= (post.content || "" ).replace(/<[^>]*>/g, '').substring(0, 110) %>...
                            </p>

                            <div
                                style="margin-top: auto; display: flex; align-items: center; justify-content: space-between; padding-top: 20px; border-top: 1px solid var(--border);">
                                <div style="display: flex; align-items: center; gap: 12px;">
                                    <img src="/images/face11.jpg" alt="Author"
                                        style="width: 38px; height: 38px; border-radius: 50%; border: 1px solid var(--border);">
                                    <div>
                                        <p style="font-size: 0.85rem; font-weight: 600; color: var(--text);">
                                            <%= (post.author && post.author.name) ? post.author.name : 'Anonymous' %>
                                        </p>
                                        <p style="font-size: 0.75rem; color: var(--text-muted);">
                                            <%= post.createdAt ? post.createdAt.toLocaleDateString('en-US', {
                                                month: 'short' , day: 'numeric' , year: 'numeric' }) : '' %>
                                        </p>
                                    </div>
                                </div>

                                <% if (user && post.author && post.author._id.toString()===user._id.toString()) { %>
                                    <div style="display: flex; gap: 12px;">
                                        <a href="/post/edit/<%= post.id %>"
                                            style="color: var(--text-muted); font-size: 1.1rem; transition: 0.3s;"><i
                                                class="fa-regular fa-pen-to-square"></i></a>
                                        <a href="/post/delete/<%= post.id %>" onclick="return confirm('Are you sure?')"
                                            style="color: #ef4444; font-size: 1.1rem; transition: 0.3s;"><i
                                                class="fa-regular fa-trash-can"></i></a>
                                    </div>
                                    <% } %>
                            </div>
                        </div>
                    </article>
                    <style>
                        .blog-card:hover {
                            transform: translateY(-8px);
                            border-color: rgba(139, 92, 246, 0.4);
                            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
                        }

                        .blog-card:hover img {
                            transform: scale(1.05);
                        }

                        .blog-card h3 a:hover {
                            color: var(--primary);
                        }
                    </style>
                    <% }); %>
                        <% } else { %>
                            <div
                                style="grid-column: 1 / -1; text-align: center; padding: 100px 20px; background: var(--card-bg); border-radius: 24px; border: 1px dashed var(--border);">
                                <i class="fa-regular fa-folder-open"
                                    style="font-size: 3rem; color: var(--text-muted); margin-bottom: 20px; display: block;"></i>
                                <h3 style="font-size: 1.5rem; margin-bottom: 10px;">No stories found yet</h3>
                                <p style="color: var(--text-muted); margin-bottom: 30px;">Be the one to spark the
                                    conversation.</p>
                                <a href="/create" class="btn" style="text-decoration: none;">Write First Story</a>
                            </div>
                            <% } %>
        </div>
    </div>

    <!-- ABOUT SECTION -->
    <section id="about" style="padding: 100px 5%; background: rgba(255, 255, 255, 0.02);">
        <div
            style="max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center;">
            <div>
                <span
                    style="color: var(--primary); font-weight: 700; letter-spacing: 2px; text-transform: uppercase; font-size: 0.8rem;">Our
                    Story</span>
                <h2 style="font-size: 2.5rem; font-weight: 800; margin: 20px 0 30px;">A space for <br><span
                        style="color: var(--primary);">meaningful</span> dialogue.</h2>
                <p style="color: var(--text-muted); font-size: 1.1rem; line-height: 1.8; margin-bottom: 20px;">
                    LUXBLOG was founded on the belief that words have the power to change the world. We provide a clean,
                    distraction-free environment for writers to express their most impactful ideas.
                </p>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 40px;">
                    <div>
                        <h4 style="font-size: 2rem; color: var(--text); font-weight: 800;">10k+</h4>
                        <p style="color: var(--text-muted); font-size: 0.9rem;">Passionate Writers</p>
                    </div>
                    <div>
                        <h4 style="font-size: 2rem; color: var(--text); font-weight: 800;">50k+</h4>
                        <p style="color: var(--text-muted); font-size: 0.9rem;">Deep Stories</p>
                    </div>
                </div>
            </div>
            <div style="position: relative;">
                <div
                    style="width: 100%; height: 500px; border-radius: 30px; overflow: hidden; transform: rotate(2deg);">
                    <img src="https://images.unsplash.com/photo-1499750310107-5fef28a66643?q=80&w=1000" alt="About"
                        style="width: 100%; height: 100%; object-fit: cover;">
                </div>
                <div
                    style="position: absolute; -bottom: 30px; -left: 30px; background: var(--primary); padding: 30px; border-radius: 20px; box-shadow: 0 20px 40px rgba(0,0,0,0.3); transform: rotate(-3deg);">
                    <i class="fa-solid fa-quote-left" style="font-size: 2rem; margin-bottom: 15px; display: block;"></i>
                    <p style="font-weight: 600; font-size: 1.1rem;">"Quality over quantity, always."</p>
                </div>
            </div>
        </div>
    </section>

    <%- include('partials/footer') %>